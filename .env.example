# Stock Dashboard environment
# Copy to .env and fill only on your local machine. Do not send real keys over chat.

# KIS / 한국투자증권 Open API
# prod = 실전, paper = 모의투자. Keep prod unless you intentionally use virtual trading.
KIS_MODE=prod
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01

# Optional: direct path/TR 테스트용. Leave blank until a specific KIS endpoint is selected.
KIS_TEST_PATH=
KIS_TEST_TR_ID=
KIS_TEST_QUERY=

# Fetch behavior
FETCH_TIMEOUT_MS=8000
DATA_STALE_SECONDS=180

# Supabase Storage publish — Option A
# Service role key is secret. Keep it only in local .env; never commit or expose it to Vercel/frontend.
SUPABASE_PUBLISH_ENABLED=0
SUPABASE_URL=https://fkjulfhlpkwavrxegaju.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=stock-dashboard
SUPABASE_STORAGE_PREFIX=data
SUPABASE_STORAGE_CACHE_CONTROL=30

# Public JSON URLs after publish:
# https://fkjulfhlpkwavrxegaju.supabase.co/storage/v1/object/public/stock-dashboard/data/latest.json
# https://fkjulfhlpkwavrxegaju.supabase.co/storage/v1/object/public/stock-dashboard/data/events.json
